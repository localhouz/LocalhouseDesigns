{
  "name": "example_objective",
  "adapter": "command_metric",
  "workspace_mode": "in_place",
  "success_summary": "Example objective completed.",
  "setup_commands": [],
  "experiment_commands": [
    "python scripts/example_eval.py --out .test-temp/example.json"
  ],
  "candidate_metric_source": {
    "path": ".test-temp/example.json",
    "key": "score.value"
  },
  "expected_artifacts": [
    ".test-temp/example.json"
  ],
  "gate": {
    "metric_checks": [
      {
        "label": "score_floor",
        "path": "score.value",
        "op": ">=",
        "value": 0.95
      }
    ],
    "require_changes": false
  }
}
