{
  "manifest_version": 3,
  "name": "LH Universe",
  "version": "0.1.0",
  "description": "Private experiment - feeds browsing context to the Localhouse Designs intent universe.",

  "permissions": ["history", "tabs", "bookmarks"],
  "host_permissions": [
    "https://localhousedesigns.com/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://localhousedesigns.com/lab/universe*",
        "http://localhost:*/lab/universe*",
        "http://127.0.0.1:*/lab/universe*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
